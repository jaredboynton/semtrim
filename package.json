{
  "name": "semtrim",
  "version": "0.1.2",
  "description": "Command-aware semantic compression of agent tool output, applied as a PreToolUse command-wrap plus best-effort PostToolUse hook.",
  "type": "module",
  "bin": { "semtrim": "hooks/semtrim.mjs" },
  "scripts": {
    "test": "find test -name '*.test.mjs' -exec node --test {} +",
    "smoke": "bash scripts/smoke-claude.sh && bash scripts/smoke-codex.sh",
    "version-check": "node scripts/bump-version.mjs --check"
  },
  "engines": { "node": ">=20" },
  "keywords": [
    "compression",
    "tokens",
    "claude-code",
    "codex",
    "hooks",
    "tool-output",
    "agentic"
  ],
  "repository": { "type": "git", "url": "git+https://github.com/jaredboynton/semtrim.git" },
  "homepage": "https://github.com/jaredboynton/semtrim#readme",
  "bugs": { "url": "https://github.com/jaredboynton/semtrim/issues" },
  "license": "MIT",
  "author": "Jared Boynton"
}
